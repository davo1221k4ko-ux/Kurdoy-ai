{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user information and preferences.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The unique user ID from Firebase Auth." },
        "displayName": { "type": "string", "description": "The user's display name." },
        "email": { "type": "string", "format": "email", "description": "The user's email address." },
        "photoURL": { "type": "string", "description": "The user's profile picture URL." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the user first logged in." },
        "updatedAt": { "type": "string", "format": "date-time", "description": "When the user profile was last updated." }
      },
      "required": ["uid", "email"]
    },
    "Chat": {
      "title": "Chat Session",
      "description": "Represents a conversation between the user and the AI.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "The unique chat ID." },
        "uid": { "type": "string", "description": "The owner of the chat." },
        "title": { "type": "string", "description": "The title of the chat session." },
        "type": { "type": "string", "enum": ["general", "coding", "student", "search", "image"], "description": "The mode of the chat." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the chat was created." },
        "updatedAt": { "type": "string", "format": "date-time", "description": "When the last message was sent." }
      },
      "required": ["id", "uid", "title", "type"]
    },
    "Message": {
      "title": "Chat Message",
      "description": "A single message within a chat session.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "The unique message ID." },
        "chatId": { "type": "string", "description": "The ID of the parent chat." },
        "uid": { "type": "string", "description": "The ID of the user who owns this message." },
        "role": { "type": "string", "enum": ["user", "assistant"], "description": "Who sent the message." },
        "content": { "type": "string", "description": "The text content of the message." },
        "imageUrl": { "type": "string", "description": "Optional URL for generated images." },
        "timestamp": { "type": "number", "description": "Unix timestamp of the message." },
        "sources": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "title": { "type": "string" },
              "uri": { "type": "string" }
            }
          }
        }
      },
      "required": ["id", "chatId", "uid", "role", "content", "timestamp"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "UserProfile",
      "description": "Stores user profiles."
    },
    "/chats/{chatId}": {
      "schema": "Chat",
      "description": "Stores chat sessions."
    },
    "/chats/{chatId}/messages/{messageId}": {
      "schema": "Message",
      "description": "Stores messages for each chat session."
    }
  }
}
